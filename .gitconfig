[credential]
    # Might be needed for Windows to force use of .git-credentials
    # if ssh key auth is not permitted by policy.
	helper = store
[user]
	useConfigOnly = true
	email = 133198355+elainajones@users.noreply.github.com
	name = Elaina Jones
	signingKey = 42A1B190F99555C1
[alias]
    b=branch
    lg = log --color --graph --pretty=format:'%C(yellow)%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    co=checkout
    b=branch
    s=status
    shove=push -f
    aa=commit --amend --author="Elaina Jones <133198355+elainajones@users.noreply.github.com>"
    diff-file-last-commit = "!f() { \
        project_root_dir=$(git rev-parse --show-toplevel); \
        echo finding full file path of $1 in $project_root_dir; \
        filepath=$(find $project_root_dir -type f -name $1); \
        echo full file path $filepath; \
        last_modified_commit_hash=$(git rev-list -1 HEAD $filepath); \
        echo last commit file modified $last_modified_commit_hash; \
        git difftool $last_modified_commit_hash^ $filepath; \
    }; f"
	serve = !"f() { \
        project_root_dir=$(basename `git rev-parse --show-toplevel`); \
        myip=$(ip -4 -o -br a | grep -oP '(?<=UP).+?(?=/)' | tr -d ' \n'); \
        echo \"serving git://${myip}/${project_root_dir}\"; \
        git daemon --verbose --export-all --base-path=.git --reuseaddr --strict-paths .git/; \
    }; f"
    # overrides via shell function: https://stackoverflow.com/a/79212558/519360
    alias-clone = clone --recurse-submodules
[commit]
	gpgSign = true
[init]
	defaultBranch = main
[core]
	autocrlf = input
    safecrlf = true
    # Enforce defaults
	excludesFile = ~/.config/git/ignore
    attributesFile = ~/.config/git/attributes
[merge]
	tool = vimdiff1
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[submodule]
	fetchJobs = 0
[fetch]
	parallel = 0
[checkout]
	workers = 0
[branch]
	sort = -creatordate
